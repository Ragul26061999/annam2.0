{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pharmacy Desktop",
  "version": "0.1.0",
  "identifier": "com.annam.pharmacy",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Pharmacy Desktop",
        "width": 1400,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "sql": {
      "preloadConnections": ["sqlite:pharmacy.db"]
    },
    "dialog": null,
    "fs": {
      "requireLiteralLeadingDot": false
    }
  }
}
